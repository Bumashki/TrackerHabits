# Скопируйте в backend/.env (именно в каталог backend/) и подставьте значения.
# Загрузка идёт из backend/.env при любом cwd (uvicorn из корня репозитория тоже ок).

# PostgreSQL. Если переменная не задана — используется SQLite ./data/app.db из config.
DATABASE_URL=postgresql://my_user:password1@194.67.66.112:5432/production

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# UUID пользователя по умолчанию (без заголовка X-User-Id). Должен совпадать с users.id в БД.
DEFAULT_USER_ID=00000000-0000-0000-0000-000000000001

# JWT (логин / регистрация). В продакшене задайте длинный случайный секрет.
JWT_SECRET_KEY=change-me-in-production-use-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
# Если false — без Bearer-токена запросы к API не принимаются (кроме /auth/*).
ALLOW_ANONYMOUS_DEFAULT_USER=true
