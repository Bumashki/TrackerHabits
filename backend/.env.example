# Скопируйте в backend/.env и подставьте значения. Файл .env не коммитьте.

# PostgreSQL (или оставьте пустым — тогда SQLite из app/config.py)
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# UUID пользователя по умолчанию (без заголовка X-User-Id). Должен совпадать с users.id в БД.
DEFAULT_USER_ID=00000000-0000-0000-0000-000000000001
